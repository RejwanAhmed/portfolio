{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": false,
        "jsx": "preserve",
        "lib": ["ESNext", "DOM"],
        "types": ["vite/client", "node"],
        "paths": {
            "@/*": ["./resources/js/*"],
            "ziggy-js": ["./vendor/tightenco/ziggy"]
        },
        "skipLibCheck": true, 
        "ignoreDeprecations": "5.0"
    },
    "include": [
        "resources/js/**/*.ts",
        "resources/js/types/**/*.d.ts",
        "resources/js/**/*.vue"
    ],
    "exclude": ["node_modules", "public"]
}